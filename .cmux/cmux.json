{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "commands": [
    {
      "name": "Site Dev",
      "keywords": ["dev", "astro", "website", "site"],
      "workspace": {
        "name": "Site",
        "cwd": ".",
        "layout": {
          "direction": "horizontal",
          "split": 0.55,
          "children": [
            {
              "direction": "vertical",
              "children": [
                {
                  "pane": {
                    "surfaces": [
                      { "type": "terminal", "name": "Claude", "command": "claude" }
                    ]
                  }
                },
                {
                  "pane": {
                    "surfaces": [
                      { "type": "terminal", "name": "Dev", "command": "pnpm dev" }
                    ]
                  }
                }
              ]
            },
            {
              "pane": {
                "surfaces": [
                  { "type": "browser", "name": "Preview", "url": "http://localhost:4321" }
                ]
              }
            }
          ]
        }
      }
    }
  ]
}
