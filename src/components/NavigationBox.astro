---
const pathname = Astro.url.pathname;
const isHomePage = pathname === '/';

const svgAttrs = 'width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"';

const icons: Record<string, string> = {
  '/': `<svg ${svgAttrs}><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>`,
  '/expertise': `<svg ${svgAttrs}><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>`,
  '/consultancy': `<svg ${svgAttrs}><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>`,
  '/work-experience': `<svg ${svgAttrs}><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>`,
  '/education': `<svg ${svgAttrs}><path d="M22 10l-10-5L2 10l10 5 10-5z"></path><path d="M6 12v5c0 0 3 3 6 3s6-3 6-3v-5"></path></svg>`,
  '/contact': `<svg ${svgAttrs}><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>`,
};

const pages = [
  { path: '/', name: 'Home' },
  { path: '/expertise', name: 'Expertise' },
  { path: '/consultancy', name: 'Consultancy' },
  { path: '/work-experience', name: 'Work Experience' },
  { path: '/education', name: 'Education' },
  { path: '/contact', name: 'Contact' },
];
---

<div class="navigation-box collapsed" id="navigation-box">
  <div class="nav-box-header">
    <button
      class="collapse-btn"
      id="collapse-btn"
      aria-label="Expand navigation"
      aria-expanded="false"
    >
      <div class="hamburger-icon">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </button>
  </div>

  <div class="nav-box-content" id="nav-box-content">
    <!-- Page Navigation -->
    <div class="nav-section">
      <h5>Pages</h5>
      <ul class="nav-list">
        {pages.map((page) => (
          <li class={pathname === page.path ? 'active' : ''}>
            <a href={page.path} class="nav-page-link">
              <span class="nav-icon" aria-hidden="true" set:html={icons[page.path]} />
              {page.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Divider and headings - hidden on homepage, populated by JS on other pages -->
    {!isHomePage && (
      <>
        <div class="nav-divider" id="nav-divider" hidden></div>
        <div class="nav-section" id="headings-section" hidden>
          <h5>On This Page</h5>
          <ul class="nav-list headings-list" id="headings-list"></ul>
        </div>
      </>
    )}
  </div>
</div>

<script is:inline>
  (function () {
    var navBox = document.getElementById('navigation-box');
    var collapseBtn = document.getElementById('collapse-btn');

    if (!navBox || !collapseBtn) return;

    var isHomePage = window.location.pathname === '/';

    // Read persisted state, fall back to viewport check
    var stored = sessionStorage.getItem('nav-collapsed');
    var isCollapsed = stored !== null ? stored === 'true' : window.innerWidth <= 1024;

    function applyCollapseState(persist) {
      if (isCollapsed) {
        navBox.classList.add('collapsed');
        collapseBtn.setAttribute('aria-label', 'Expand navigation');
        collapseBtn.setAttribute('aria-expanded', 'false');
      } else {
        navBox.classList.remove('collapsed');
        collapseBtn.setAttribute('aria-label', 'Collapse navigation');
        collapseBtn.setAttribute('aria-expanded', 'true');
      }
      if (persist) sessionStorage.setItem('nav-collapsed', String(isCollapsed));
    }

    applyCollapseState(false);

    collapseBtn.addEventListener('click', function () {
      isCollapsed = !isCollapsed;
      applyCollapseState(true);
    });

    window.addEventListener('resize', function () {
      var shouldCollapse = window.innerWidth <= 1024;
      if (shouldCollapse !== isCollapsed) {
        isCollapsed = shouldCollapse;
        applyCollapseState(true);
      }
    });

    // Auto-close on mobile when a page link is clicked
    var pageLinks = navBox.querySelectorAll('.nav-page-link');
    pageLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        if (window.innerWidth <= 1024) {
          isCollapsed = true;
          applyCollapseState(true);
        }
      });
    });

    // Heading scan - skip on homepage
    if (isHomePage) return;

    var navDivider = document.getElementById('nav-divider');
    var headingsSection = document.getElementById('headings-section');
    var headingsList = document.getElementById('headings-list');

    if (!headingsList) return;

    function scanHeadings() {
      var mainContent = document.querySelector('.main-content');
      if (!mainContent) return;
      var headingElements = mainContent.querySelectorAll('h2, h4, h5, h6');
      var items = [];

      headingElements.forEach(function (heading, index) {
        var text = heading.textContent || '';
        var level = parseInt(heading.tagName.charAt(1), 10);

        var id = heading.id;
        if (!id) {
          id = 'heading-' + index;
          heading.id = id;
        }

        items.push({ id: id, text: text, level: level });
      });

      if (!headingsList) return;

      headingsList.innerHTML = '';

      if (items.length > 0) {
        items.forEach(function (item) {
          var li = document.createElement('li');
          li.className = 'heading-level-' + item.level;

          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'heading-link';
          btn.textContent = item.text;
          btn.addEventListener('click', function () {
            var el = document.getElementById(item.id);
            if (el) {
              el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
            if (window.innerWidth <= 1024) {
              isCollapsed = true;
              applyCollapseState(true);
            }
          });

          li.appendChild(btn);
          headingsList.appendChild(li);
        });

        if (navDivider) navDivider.hidden = false;
        if (headingsSection) headingsSection.hidden = false;
      } else {
        if (navDivider) navDivider.hidden = true;
        if (headingsSection) headingsSection.hidden = true;
      }
    }

    scanHeadings();
  })();
</script>
