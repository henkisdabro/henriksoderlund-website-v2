---
import { actions } from 'astro:actions';
import { TURNSTILE_SITE_KEY } from 'astro:env/client';

const result = Astro.getActionResult(actions.contact);
const success = result?.data?.success;
const error = result?.error;
---

{success && (
  <div class="form-success">
    <div class="form-success-icon">&#10003;</div>
    <h3>Message sent successfully</h3>
    <p>Thank you for reaching out. I'll get back to you within one business day.</p>
  </div>
)}

{error && (
  <div class="form-error">
    <p><strong>Something went wrong.</strong> Please try again or email me directly at <a href="mailto:henrik@henriksoderlund.com">henrik@henriksoderlund.com</a>.</p>
  </div>
)}

{!success && (
  <form method="POST" action={actions.contact} class="contact-form">
    <div class="form-row">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required maxlength="100" placeholder="Your name" />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required maxlength="200" placeholder="you@example.com" />
      </div>
    </div>
    <div class="form-group">
      <label for="message">Message</label>
      <textarea id="message" name="message" required maxlength="2000" rows="6" placeholder="Tell me about your project or question..."></textarea>
    </div>
    <div class="form-footer">
      <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>
      <button type="submit" class="submit-btn">Send Message</button>
    </div>
  </form>
)}

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
