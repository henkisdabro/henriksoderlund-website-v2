---
import linkedinIcon from '../assets/logos/linkedin.svg';
import { LINKEDIN_URL } from '../data/links';
---

<a
  href={LINKEDIN_URL}
  target="_blank"
  rel="noopener noreferrer"
  class="linkedin-link"
  aria-label="Visit Henrik's LinkedIn Profile"
>
  <img
    src={linkedinIcon.src}
    alt="LinkedIn"
    class="linkedin-icon"
  />
</a>
