---
import githubIcon from '../assets/logos/github.svg';
import { GITHUB_URL } from '../data/links';
---

<a
  href={GITHUB_URL}
  target="_blank"
  rel="noopener noreferrer"
  class="github-link"
  aria-label="Visit Henrik's GitHub Profile"
>
  <img
    src={githubIcon.src}
    alt="GitHub"
    class="github-icon"
  />
</a>
