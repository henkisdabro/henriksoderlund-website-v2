---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import swedenFlag from '../assets/flags/se.svg';
import '../styles/content-entry.css';
---

<BaseLayout
  title="Education & Qualifications | Henrik Söderlund"
  description="Educational background of Henrik Söderlund - Master of Music from Lund University, Sweden."
>
  <div class="education-page">
    <h1>Education</h1>

    <section class="content-entry">
      <h2 id="tertiary-education">
        <img src={swedenFlag.src} alt="Sweden" class="country-flag" width="16" height="12" />{" "}
        Tertiary Education
      </h2>
      <p class="dates">1999–2006</p>
      <p>Master of Music [M.Mus.] Instrument: Trombone at Lund University</p>
      <p>Malmö, Sweden</p>
      <p>
        Seven years of conservatoire training at Lund University's Malmö Academy of Music, culminating in a Master of Music degree. The programme demanded rigorous daily practice, public performance under pressure, and deep collaboration with ensembles and conductors. These disciplines - structured iteration, creative problem-solving, and performing under scrutiny - translate directly into how I approach technology work: methodical preparation, clear communication, and delivery that holds up when it matters.
      </p>
    </section>

    <section class="content-entry">
      <h2 id="secondary-education">
        <img src={swedenFlag.src} alt="Sweden" class="country-flag" width="16" height="12" />{" "}
        Secondary Education
      </h2>
      <p class="dates">1996–1999</p>
      <p>Natural Sciences at Kattegattgymnasiet</p>
      <p>Malmö, Sweden</p>
      <p>
        Three-year Natural Sciences programme providing a STEM foundation in mathematics, physics, and chemistry alongside the Swedish upper-secondary curriculum.
      </p>
    </section>

    <section class="content-entry">
      <h2 id="primary-education">
        <img src={swedenFlag.src} alt="Sweden" class="country-flag" width="16" height="12" /> Primary
        Education
      </h2>
      <p class="dates">1987–1996</p>
      <p>Elementary at Örjanskolan</p>
      <p>Halmstad, Sweden</p>
    </section>
  </div>
</BaseLayout>

