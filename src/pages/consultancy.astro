---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { consultationData } from '../data/consultation';
import { CALENDLY_URL } from '../data/links';

const serviceNames = consultationData.services.pillars.map(pillar => ({
  "@type": "Offer",
  "itemOffered": { "@type": "Service", "name": pillar.name, "description": pillar.description }
}));

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": consultationData.faq.items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://www.henriksoderlund.com/consultancy#service",
  "name": "Henrik Söderlund - Strategic Technology Consultancy",
  "description": "AI automation, analytics infrastructure, team upskilling, and digital product consulting. Working systems that deliver measurable outcomes for businesses seeking to leverage cutting-edge technology solutions.",
  "url": "https://www.henriksoderlund.com/consultancy",
  "provider": {
    "@id": "https://www.henriksoderlund.com/#person"
  },
  "serviceType": "AI Automation & Technology Consulting",
  "areaServed": [
    {
      "@type": "City",
      "name": "Perth"
    },
    {
      "@type": "Country",
      "name": "Australia"
    }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Consulting Services",
    "itemListElement": serviceNames
  },
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceUrl": CALENDLY_URL,
    "availableLanguage": [
      { "@type": "Language", "name": "English", "alternateName": "en" },
      { "@type": "Language", "name": "Swedish", "alternateName": "sv" }
    ]
  }
};
---

<BaseLayout
  title="Consultancy | Henrik Söderlund"
  description="Strategic technology consultancy - AI automation, analytics implementation, and digital transformation. Working systems that deliver measurable outcomes."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <div class="consultation-page">
    <section class="consultancy-hero">
      <h1>{consultationData.hero.title}</h1>
      <p class="hero-subtitle">{consultationData.hero.subtitle}</p>
      <p>{consultationData.hero.statement}</p>
    </section>

    <section class="ideal-clients-section">
      <h2 id="ideal-clients">{consultationData.idealClients.title}</h2>
      <div class="client-profiles">
        {consultationData.idealClients.profiles.map(profile => (
          <div class="client-profile">
            <strong>{profile.label}</strong> {profile.description}
          </div>
        ))}
      </div>
    </section>

    <section class="services-section">
      <h2 id="services">{consultationData.services.title}</h2>
      <div class="service-pillars">
        {consultationData.services.pillars.map(pillar => (
          <div class="service-pillar">
            <h3>{pillar.name}</h3>
            <p class="pillar-description">{pillar.description}</p>
            <ul>
              {pillar.outcomes.map(outcome => (
                <li>{outcome}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="engagement-section">
      <h2 id="engagement-models">{consultationData.engagementModels.title}</h2>
      <p>{consultationData.engagementModels.intro}</p>
      <div class="engagement-models">
        {consultationData.engagementModels.models.map(model => (
          <div class="engagement-model">
            <h3>{model.name}</h3>
            <p>{model.description}</p>
            <p class="engagement-details">{model.details}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="case-study-section">
      <h2 id="case-study">Case Study</h2>
      <div class="case-study-headline">
        <p class="headline-metrics">{consultationData.caseStudy.headline}</p>
        <h3>{consultationData.caseStudy.title}</h3>
      </div>

      <div class="client-overview">
        <div class="client-info">
          <strong>Client:</strong> {consultationData.caseStudy.client.type}<br />
          <strong>Team Size:</strong> {consultationData.caseStudy.client.team}<br />
          <strong>Core Challenge:</strong> {consultationData.caseStudy.client.challenge}
        </div>
      </div>

      <div class="case-study-content">
        <div class="challenge-section">
          <h3>{consultationData.caseStudy.challenge.title}</h3>
          <p>{consultationData.caseStudy.challenge.description}</p>
          <ul class="pain-points">
            {consultationData.caseStudy.challenge.painPoints.map(point => (
              <li>{point}</li>
            ))}
          </ul>
        </div>

        <div class="solution-section">
          <h3>{consultationData.caseStudy.solution.title}</h3>
          <p>{consultationData.caseStudy.solution.description}</p>
          <div class="solution-components">
            {consultationData.caseStudy.solution.components.map(component => (
              <div class="solution-component">
                <h4>{component.name}</h4>
                <p>{component.description}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="results-section">
          <h3>{consultationData.caseStudy.results.title}</h3>
          <p>{consultationData.caseStudy.results.description}</p>
          <div class="results-metrics">
            {consultationData.caseStudy.results.metrics.map(metric => (
              <div class="metric-card">
                <div class="metric-value">{metric.value}</div>
                <div class="metric-name">{metric.metric}</div>
                <div class="metric-description">{metric.description}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="technology-section">
          <h3>{consultationData.caseStudy.technologies.title}</h3>
          <ul class="technology-list">
            {consultationData.caseStudy.technologies.items.map(tech => (
              <li>{tech}</li>
            ))}
          </ul>
        </div>

        <div class="testimonial-section">
          <blockquote class="case-study-testimonial">
            <p>"{consultationData.caseStudy.testimonial.quote}"</p>
            <cite>- {consultationData.caseStudy.testimonial.author}</cite>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="policy-section">
      <h2 id="quality-guarantee">{consultationData.qualityGuarantee.title}</h2>
      <p>{consultationData.qualityGuarantee.paragraph}</p>
    </section>

    <section class="faq-section">
      <h2 id="faq">{consultationData.faq.title}</h2>
      {consultationData.faq.items.map(item => (
        <details class="faq-item">
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </section>

    <section class="calendar-section">
      <h2 id="contact">Let's Talk</h2>
      <p>Book a complimentary 30-minute discovery call. You will leave with actionable recommendations for your situation, regardless of whether we work together.</p>
      <div class="cta-buttons">
        <a href={CALENDLY_URL} target="_blank" rel="noopener noreferrer" class="cta-primary">Book a Discovery Call</a>
        <a href="/contact" class="cta-secondary">Send a Message</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style is:global>
/* Consultation Page Styles */
.consultancy-hero {
  margin-bottom: 3rem;
}

.consultancy-hero h1 {
  margin-bottom: 1rem;
  color: var(--color-text-heading);
}

.ideal-clients-section,
.services-section,
.engagement-section,
.policy-section,
.calendar-section,
.case-study-section {
  margin-bottom: 3rem;
}

.hero-subtitle {
  font-size: 1.2rem;
  font-weight: 500;
  color: var(--color-text-heading);
  line-height: 1.5;
  margin-bottom: 1rem;
}

.ideal-clients-section h2,
.services-section h2,
.engagement-section h2,
.policy-section h2,
.calendar-section h2 {
  font-size: 1.8rem;
  margin-bottom: 1rem;
  color: var(--color-text-heading);
}

.ideal-clients-section h2,
.services-section h2 {
  margin-bottom: 1.5rem;
}

/* Shared card styles */
.client-profile,
.service-pillar,
.engagement-model,
.client-overview {
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border-primary);
  border-radius: 8px;
  padding: 1.5rem;
}

/* Who I Work With */
.client-profiles {
  display: grid;
  gap: 1rem;
}

.client-profile {
  padding: 1.25rem;
  line-height: 1.6;
  color: var(--color-text-primary);
}

.client-profile strong {
  color: var(--color-text-heading);
}

/* Service Pillars */
.service-pillars {
  display: grid;
  gap: 2rem;
}

.service-pillar h3 {
  font-size: 1.4rem;
  color: var(--color-text-heading);
  margin: 0 0 0.75rem 0;
}

.pillar-description {
  font-size: 1rem;
  color: var(--color-text-primary);
  font-weight: 500;
  margin-bottom: 1rem;
  line-height: 1.5;
}

.service-pillar ul {
  list-style: none;
  padding-left: 0;
  margin: 0;
}

.service-pillar li {
  margin-bottom: 0.6rem;
  padding-left: 1.5rem;
  position: relative;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.service-pillar li:before {
  content: "\25B6";
  position: absolute;
  left: 0;
  color: var(--color-marker);
  font-size: 0.8rem;
}

/* Engagement Models */
.engagement-models {
  display: grid;
  gap: 1.5rem;
  margin-top: 1.5rem;
}

.engagement-model h3 {
  font-size: 1.3rem;
  color: var(--color-text-heading);
  margin: 0 0 0.75rem 0;
}

.engagement-model p {
  color: var(--color-text-primary);
  line-height: 1.6;
}

.engagement-details {
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  margin-top: 0.5rem;
}

/* Case Study Section Styles */
.case-study-section {
  margin-bottom: 3rem;
}

.case-study-headline {
  margin-bottom: 1.5rem;
}

.headline-metrics {
  font-size: 1.3rem;
  font-weight: 600;
  color: var(--color-text-heading);
  margin-bottom: 0.5rem;
  line-height: 1.4;
}

.case-study-headline h2 {
  font-size: 1.2rem;
  color: var(--color-text-secondary);
  font-weight: 400;
  margin: 0;
}

.client-overview {
  margin-bottom: 2rem;
}

.client-info {
  font-size: 0.9rem;
  line-height: 1.6;
  color: var(--color-text-primary);
}

.case-study-content {
  display: grid;
  gap: 1.5rem;
}

.challenge-section,
.solution-section,
.results-section,
.technology-section,
.testimonial-section {
  background: var(--color-bg-primary);
  border-radius: 8px;
  padding: 1.5rem;
  border: 1px solid var(--color-border-primary);
}

.challenge-section h3,
.solution-section h3,
.results-section h3,
.technology-section h3 {
  font-size: 1.3rem;
  color: var(--color-text-heading);
  margin: 0 0 1rem 0;
  font-weight: 600;
}

.pain-points {
  list-style: disc;
  margin: 1rem 0 1rem 2rem;
}

.pain-points li {
  margin-bottom: 0.5rem;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.solution-components {
  display: grid;
  gap: 0.5rem;
  margin-top: 1rem;
}

.solution-component {
  background: var(--color-bg-secondary);
  border-radius: 4px;
  padding: 0.75rem;
  border: 1px solid var(--color-border-primary);
}

.solution-component h4 {
  font-size: 1rem;
  color: var(--color-text-heading);
  margin: 0 0 0.25rem 0;
  font-weight: 600;
}

.solution-component p {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: 0.85rem;
  line-height: 1.4;
}

.results-metrics {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0.75rem;
  margin-top: 1rem;
}

.metric-card {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-primary);
  border-radius: 4px;
  padding: 1rem;
  text-align: left;
}

.metric-value {
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 0.25rem;
  color: var(--color-text-primary);
}

.metric-name {
  font-size: 0.8rem;
  font-weight: 500;
  margin-bottom: 0.25rem;
  color: var(--color-text-secondary);
  text-transform: none;
  letter-spacing: 0;
}

.metric-description {
  font-size: 0.75rem;
  color: var(--color-text-tertiary);
  line-height: 1.3;
}

.technology-list {
  list-style: disc;
  margin-left: 2rem;
  margin: 1rem 0 1rem 2rem;
  display: block;
}

.technology-list li {
  margin-bottom: 0.5rem;
  color: var(--color-text-secondary);
  font-size: 0.9rem;
  line-height: 1.4;
}

.testimonial-section {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border-primary);
  text-align: center;
}

.case-study-testimonial {
  margin: 0;
  border: none;
  padding: 0;
}

.case-study-testimonial p {
  font-size: 1rem;
  line-height: 1.6;
  margin: 0 0 1rem 0;
  font-style: italic;
  color: var(--color-text-secondary);
}

.case-study-testimonial cite {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-text-heading);
  font-style: normal;
}

/* Details/Summary accordion for case study */
.case-study-section details > summary {
  cursor: pointer;
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.case-study-section details > summary::-webkit-details-marker {
  display: none;
}

.case-study-section details > summary::marker {
  display: none;
  content: '';
}

/* Consultancy page mobile responsive */
@media (max-width: 768px) {
  .case-study-section {
    margin-bottom: 2rem;
  }

  .client-overview,
  .challenge-section,
  .solution-section,
  .results-section,
  .technology-section,
  .testimonial-section {
    padding: 1rem;
  }

  .results-metrics {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .metric-card {
    padding: 1rem;
  }

  .metric-value {
    font-size: 1.2rem;
  }

  .solution-components {
    gap: 0.75rem;
  }

  .case-study-testimonial p {
    font-size: 0.9rem;
  }
}
</style>
