---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { consultationData } from '../data/consultation';
import { CALENDLY_URL } from '../data/links';

const serviceNames = consultationData.services.pillars.flatMap(pillar =>
  [{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": pillar.name, "description": pillar.description } }]
);

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://www.henriksoderlund.com/consultancy#service",
  "name": "Henrik Söderlund - Strategic Technology Consultancy",
  "description": "AI automation, analytics implementation, and digital transformation consulting services for businesses seeking to leverage cutting-edge technology solutions.",
  "url": "https://www.henriksoderlund.com/consultancy",
  "provider": {
    "@id": "https://www.henriksoderlund.com/#person"
  },
  "serviceType": "Technology Consulting",
  "areaServed": [
    {
      "@type": "City",
      "name": "Perth"
    },
    {
      "@type": "Country",
      "name": "Australia"
    }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Consulting Services",
    "itemListElement": serviceNames
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Service",
    "url": CALENDLY_URL,
    "availableLanguage": ["English", "Swedish"]
  }
};
---

<BaseLayout
  title="Consultancy | Henrik Söderlund"
  description="Strategic technology consultancy - AI automation, analytics implementation, and digital transformation. Working systems that deliver measurable outcomes."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <div class="consultation-page">
    <section class="hero-section">
      <h1>{consultationData.hero.title}</h1>
      <p class="hero-subtitle">{consultationData.hero.subtitle}</p>
      <p>{consultationData.hero.statement}</p>
    </section>

    <section class="ideal-clients-section">
      <h2>{consultationData.idealClients.title}</h2>
      <div class="client-profiles">
        {consultationData.idealClients.profiles.map(profile => (
          <div class="client-profile">
            <strong>{profile.label}</strong> {profile.description}
          </div>
        ))}
      </div>
    </section>

    <section class="services-section">
      <h2>{consultationData.services.title}</h2>
      <div class="service-pillars">
        {consultationData.services.pillars.map(pillar => (
          <div class="service-pillar">
            <h3>{pillar.name}</h3>
            <p class="pillar-description">{pillar.description}</p>
            <ul>
              {pillar.outcomes.map(outcome => (
                <li>{outcome}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="engagement-section">
      <h2>{consultationData.engagementModels.title}</h2>
      <p>{consultationData.engagementModels.intro}</p>
      <div class="engagement-models">
        {consultationData.engagementModels.models.map(model => (
          <div class="engagement-model">
            <h3>{model.name}</h3>
            <p>{model.description}</p>
            <p class="engagement-details">{model.details}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="case-study-section">
      <div class="case-study-headline">
        <p class="headline-metrics">{consultationData.caseStudy.headline}</p>
        <h2>{consultationData.caseStudy.title}</h2>
      </div>

      <div class="client-overview">
        <div class="client-info">
          <strong>Client:</strong> {consultationData.caseStudy.client.type}<br />
          <strong>Team Size:</strong> {consultationData.caseStudy.client.team}<br />
          <strong>Core Challenge:</strong> {consultationData.caseStudy.client.challenge}
        </div>
      </div>

      <div class="case-study-content">
        <div class="challenge-section">
          <h3>{consultationData.caseStudy.challenge.title}</h3>
          <p>{consultationData.caseStudy.challenge.description}</p>
          <ul class="pain-points">
            {consultationData.caseStudy.challenge.painPoints.map(point => (
              <li>{point}</li>
            ))}
          </ul>
        </div>

        <div class="solution-section">
          <h3>{consultationData.caseStudy.solution.title}</h3>
          <p>{consultationData.caseStudy.solution.description}</p>
          <div class="solution-components">
            {consultationData.caseStudy.solution.components.map(component => (
              <div class="solution-component">
                <h4>{component.name}</h4>
                <p>{component.description}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="results-section">
          <h3>{consultationData.caseStudy.results.title}</h3>
          <p>{consultationData.caseStudy.results.description}</p>
          <div class="results-metrics">
            {consultationData.caseStudy.results.metrics.map(metric => (
              <div class="metric-card">
                <div class="metric-value">{metric.value}</div>
                <div class="metric-name">{metric.metric}</div>
                <div class="metric-description">{metric.description}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="technology-section">
          <h3>{consultationData.caseStudy.technologies.title}</h3>
          <ul class="technology-list">
            {consultationData.caseStudy.technologies.items.map(tech => (
              <li>{tech}</li>
            ))}
          </ul>
        </div>

        <div class="testimonial-section">
          <blockquote class="case-study-testimonial">
            <p>"{consultationData.caseStudy.testimonial.quote}"</p>
            <cite>- {consultationData.caseStudy.testimonial.author}</cite>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="policy-section">
      <h2>{consultationData.qualityGuarantee.title}</h2>
      <p>{consultationData.qualityGuarantee.paragraph}</p>
    </section>

    <section class="calendar-section">
      <h2>Let's Talk</h2>
      <p>Book a complimentary 30-minute discovery call. You will leave with actionable recommendations for your situation, regardless of whether we work together.</p>
      <div class="cta-buttons">
        <a href={CALENDLY_URL} target="_blank" rel="noopener noreferrer" class="cta-primary">Book a Discovery Call</a>
        <a href="/contact" class="cta-secondary">Send a Message</a>
      </div>
    </section>
  </div>
</BaseLayout>
