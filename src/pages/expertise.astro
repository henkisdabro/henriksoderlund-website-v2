---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { expertiseData } from '../data/expertise';
import { GITHUB_URL } from '../data/links';
import dashboardImage from '../assets/images/screenshots/dashboard.webp';
import wikiImage from '../assets/images/screenshots/wiki.webp';
import utmhubImage from '../assets/images/screenshots/utmhub.webp';
import rottoSnorkelImage from '../assets/images/screenshots/rotto-snorkel.webp';
import automationDiagramImage from '../assets/images/screenshots/automation-diagram.webp';

const imageMap: Record<string, ImageMetadata> = {
  dashboardImage,
  wikiImage,
  utmhubImage,
  rottoSnorkelImage,
  automationDiagramImage,
};

import { sectionIcons } from '../utils/sectionIcons';
---

<BaseLayout
  title="Technical Expertise | Henrik Söderlund"
  description="Technical expertise, platform mastery, and open-source contributions by Henrik Söderlund - Technology Leader & AI Innovator."
>
  <div class="expertise-page">
    <h1>Expertise</h1>

    <section class="consultancy-section">
      <h2 id="overview"><span class="section-icon" aria-hidden="true" set:html={sectionIcons.rocket} />{expertiseData.intro.title}</h2>
      <p>{expertiseData.intro.paragraph}</p>
    </section>

    <section class="showcase-section">
      <h2 id="showcase-projects"><span class="section-icon" aria-hidden="true" set:html={sectionIcons.layers} />{expertiseData.showcase.title}</h2>
      <div class="carousel">
        <div class="carousel-viewport">
          <div class="carousel-track">
            {expertiseData.showcase.projects.map((project, i) => {
              const hasImage = project.image && imageMap[project.image];
              const isLink = !!project.url;
              const Tag = isLink ? 'a' : 'div';
              const linkProps = isLink ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' } : {};
              return (
                <Tag
                  {...linkProps}
                  class={`showcase-card${i === 0 ? ' showcase-card--active' : ''}${isLink ? '' : ' showcase-card--static'}`}
                  style={`--card-accent: ${project.accentColour}`}
                  data-index={i}
                  aria-hidden={i !== 0 ? "true" : undefined}
                  tabindex={i !== 0 ? -1 : undefined}
                  inert={i !== 0 ? true : undefined}
                >
                  <div class="showcase-card-image">
                    {hasImage ? (
                      <img
                        src={imageMap[project.image].src}
                        alt={`${project.title} screenshot`}
                        width={imageMap[project.image].width}
                        height={imageMap[project.image].height}
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="showcase-card-placeholder">
                        <span class="showcase-card-placeholder-text">{project.title}</span>
                      </div>
                    )}
                  </div>
                  <div class="showcase-card-content">
                    <div class="showcase-card-header">
                      <span class="showcase-type-badge">{project.type}</span>
                      <h3>{project.title}</h3>
                    </div>
                    <p class="showcase-tagline">{project.tagline}</p>
                    <p class="showcase-description">{project.description}</p>
                    <div class="showcase-tags">
                      {project.tags.map((tag: string) => <span class="showcase-tag">{tag}</span>)}
                    </div>
                    {isLink && <span class="showcase-cta">Visit {project.title} &rarr;</span>}
                  </div>
                </Tag>
              );
            })}
          </div>
        </div>
        <button class="carousel-btn carousel-btn--prev" aria-label="Previous project" type="button">&lsaquo;</button>
        <button class="carousel-btn carousel-btn--next" aria-label="Next project" type="button">&rsaquo;</button>
        <div class="carousel-dots">
          {expertiseData.showcase.projects.map((_, i) => (
            <button class={`carousel-dot${i === 0 ? ' carousel-dot--active' : ''}`} aria-label={`Go to slide ${i + 1}`} data-slide={i} type="button" />
          ))}
        </div>
      </div>
    </section>

    <section class="leadership-section">
      <h2 id="leadership"><span class="section-icon" aria-hidden="true" set:html={sectionIcons.users} />{expertiseData.leadershipExpertise.title}</h2>
      <p>{expertiseData.leadershipExpertise.paragraph}</p>
      <div class="skills-grid">
        {expertiseData.leadershipExpertise.categories.map(category => (
          <div class="skill-category">
            <h3>{category.category}</h3>
            <div class="skills-minimal-pills">
              {category.skills.map(skill => <span class="skill-pill-minimal">{skill}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="technical-skills-section">
      <h2 id="technical-skills"><span class="section-icon" aria-hidden="true" set:html={sectionIcons.wrench} />Technical Expertise & Platform Mastery</h2>
      <div class="skills-grid">
        {expertiseData.skillsGrid.map(category => (
          <div class="skill-category">
            <h3>{category.category}</h3>
            <div class="skills-minimal-pills">
              {category.skills.map(skill => <span class="skill-pill-minimal">{skill}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="ai-tooling-section">
      <h2 id="ai-tooling"><span class="section-icon" aria-hidden="true" set:html={sectionIcons.cpu} />{expertiseData.aiTooling.title}</h2>
      <p>{expertiseData.aiTooling.paragraph}</p>
      <div class="skills-grid">
        {expertiseData.aiTooling.categories.map(category => (
          <div class="skill-category">
            <h3>{category.category}</h3>
            <div class="skills-minimal-pills">
              {category.skills.map(skill => <span class="skill-pill-minimal">{skill}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="platform-experience">
      <h2 id="platform-experience"><span class="section-icon" aria-hidden="true" set:html={sectionIcons.trendingUp} />{expertiseData.platformExperience.title}</h2>
      <p>{expertiseData.platformExperience.paragraph}</p>
      <div class="skills-minimal-pills">
        {expertiseData.platformExperience.platforms.map(platform => <span class="skill-pill-minimal">{platform}</span>)}
      </div>
    </section>

    <section class="github-contributions">
      <h2 id="github-contributions"><span class="section-icon" aria-hidden="true" set:html={sectionIcons.gitBranch} />{expertiseData.githubContributions.title}</h2>

      <div class="opensource-grid">
        {expertiseData.githubContributions.contributions.map(contribution => (
          <a href={contribution.url} target="_blank" rel="noopener noreferrer" class="opensource-tile">
            <div class="opensource-tile-header">
              <svg class="opensource-tile-icon" width="20" height="20" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
              <h3>{contribution.title}</h3>
            </div>
            <p class="opensource-tile-description">{contribution.description}</p>
            <span class="opensource-tile-link">View on GitHub &rarr;</span>
          </a>
        ))}
      </div>

      <div class="github-activity">
        <h3>GitHub Contribution Activity</h3>
        <p class="github-activity-description">Daily contributions across public and private repositories over the past year. View my full profile on <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>.</p>
        <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="github-chart-link">
          <img
            src="https://ghchart.rshah.org/henkisdabro"
            alt="Henrik's GitHub contribution graph showing daily activity over the past year"
            class="github-chart"
            width="663"
            height="104"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  function initCarousel(): void {
    const carousel = document.querySelector<HTMLElement>('.carousel');
    if (!carousel) return;

    const trackEl = carousel.querySelector<HTMLElement>('.carousel-track');
    const cards = carousel.querySelectorAll<HTMLElement>('.showcase-card');
    const dots = carousel.querySelectorAll<HTMLElement>('.carousel-dot');
    const prevBtn = carousel.querySelector<HTMLElement>('.carousel-btn--prev');
    const nextBtn = carousel.querySelector<HTMLElement>('.carousel-btn--next');
    if (!trackEl || cards.length === 0) return;

    // Re-bind after the null guard so TypeScript narrows the type in closures
    const track: HTMLElement = trackEl;
    const total = cards.length;
    let current = 0;

    function goTo(index: number): void {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;

      cards.forEach((card, i) => {
        const isActive = i === current;
        card.classList.toggle('showcase-card--active', isActive);
        card.setAttribute('aria-hidden', String(!isActive));
        card.setAttribute('tabindex', isActive ? '0' : '-1');
        card.inert = !isActive;
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('carousel-dot--active', i === current);
      });
    }

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const index = Number(card.dataset.index);
        if (index !== current) {
          e.preventDefault();
          goTo(index);
        }
      });
    });

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    dots.forEach(dot => {
      dot.addEventListener('click', () => goTo(Number(dot.dataset.slide)));
    });

    carousel.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });

    const AUTO_DELAY = 5000;
    let timer = setInterval(() => goTo(current + 1), AUTO_DELAY);

    function pauseAuto(): void { clearInterval(timer); }
    function resumeAuto(): void {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), AUTO_DELAY);
    }

    carousel.addEventListener('mouseenter', pauseAuto);
    carousel.addEventListener('mouseleave', resumeAuto);
    carousel.addEventListener('focusin', pauseAuto);
    carousel.addEventListener('focusout', resumeAuto);

    // Touch swipe support
    let touchStartX = 0;
    let touchStartY = 0;
    let touchDeltaX = 0;
    let swiping: boolean | null = null; // null = undecided, true = horizontal, false = vertical

    carousel.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      swiping = null;
      pauseAuto();
    }, { passive: true });

    carousel.addEventListener('touchmove', (e) => {
      const dx = e.touches[0].clientX - touchStartX;
      const dy = e.touches[0].clientY - touchStartY;

      // Decide direction intent after 10px of movement
      if (swiping === null && (Math.abs(dx) > 10 || Math.abs(dy) > 10)) {
        swiping = Math.abs(dx) > Math.abs(dy);
      }

      if (!swiping) return; // vertical scroll — don't interfere

      e.preventDefault();
      touchDeltaX = dx;
      track.style.transition = 'none';
      track.style.transform = `translateX(calc(-${current * 100}% + ${touchDeltaX}px))`;
    }, { passive: false });

    carousel.addEventListener('touchend', () => {
      track.style.transition = '';

      if (swiping && Math.abs(touchDeltaX) > 50) {
        goTo(touchDeltaX < 0 ? current + 1 : current - 1);
      } else {
        goTo(current); // snap back
      }

      touchDeltaX = 0;
      swiping = null;
      resumeAuto();
    }, { passive: true });

    // Clean up on view transition navigation
    document.addEventListener('astro:before-preparation', () => {
      clearInterval(timer);
    }, { once: true });

    goTo(0);
  }

  initCarousel();
</script>
