---
import SEO from '../components/SEO.astro';
import NavigationBox from '../components/NavigationBox.astro';
import GitHubLink from '../components/GitHubLink.astro';
import LinkedInLink from '../components/LinkedInLink.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Footer from '../components/Footer.astro';
import { GITHUB_URL, LINKEDIN_URL } from '../data/links';
import '../styles/theme.css';
import '../styles/index.css';
import '../styles/App.css';

interface Props {
  title: string;
  description: string;
  ogType?: 'profile' | 'website';
}

const { title, description, ogType = 'website' } = Astro.props;

const personSchemaJSON = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://www.henriksoderlund.com/#person",
  "name": "Henrik Söderlund",
  "url": "https://www.henriksoderlund.com/",
  "image": "https://www.henriksoderlund.com/og_image.png",
  "jobTitle": "Technology Leader & Automation Architect",
  "description": "Technology Leader and Automation Architect building automation, analytics infrastructure, and digital products that free teams to focus on higher-value work. Agency founder and enterprise operator based in Perth, Australia.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Perth",
    "addressRegion": "WA",
    "addressCountry": "AU"
  },
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Independent AI & Technology Consultant",
    "description": "Independent consultant delivering AI automation, analytics infrastructure, and digital products",
    "occupationLocation": {
      "@type": "City",
      "name": "Perth"
    }
  },
  "knowsAbout": [
    "Artificial Intelligence",
    "Workflow Automation",
    "AI Coding Assistants",
    "Technology Leadership",
    "Analytics Infrastructure",
    "Server-Side Tracking",
    "Google Analytics",
    "Google Tag Manager",
    "Measurement Frameworks",
    "Cloudflare Workers",
    "LLM API Integration",
    "Digital Products",
    "Programmatic Advertising",
    "Marketing Technology",
    "Data Pipeline Architecture",
    "Team Building & Mentoring",
    "Process Automation",
    "Python Programming",
    "React Development"
  ],
  "alumniOf": [
    {
      "@type": "CollegeOrUniversity",
      "name": "Lund University",
      "sameAs": "https://www.lu.se/",
      "department": {
        "@type": "EducationalOrganization",
        "name": "Malmö Academy of Music"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Malmö",
        "addressCountry": "SE"
      }
    }
  ],
  "knowsLanguage": [
    {
      "@type": "Language",
      "name": "English",
      "alternateName": "en"
    },
    {
      "@type": "Language",
      "name": "Swedish",
      "alternateName": "sv"
    }
  ],
  "sameAs": [
    GITHUB_URL,
    LINKEDIN_URL
  ],
  "award": [
    "MFA Changer Recognition 2024 - Initiative Australia",
    "Advertising+Marketing AOTY Best Local Media Agency 2021 - Creme Digital"
  ]
});

const websiteSchemaJSON = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://www.henriksoderlund.com/#website",
  "name": "Henrik Söderlund - Technology Leader & Automation Architect",
  "url": "https://www.henriksoderlund.com/",
  "description": "The personal website of Henrik Söderlund, a Technology Leader and Automation Architect based in Perth, Australia.",
  "author": {
    "@id": "https://www.henriksoderlund.com/#person"
  }
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <!-- Theme detection - must run before any paint to prevent FOUC -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', theme);

        window.__setTheme = function(t) {
          // Enable transitions only during theme switch
          document.documentElement.classList.add('theme-transitioning');
          document.documentElement.setAttribute('data-theme', t);
          localStorage.setItem('theme', t);
          setTimeout(function() { document.documentElement.classList.remove('theme-transitioning'); }, 350);
          // Re-render Turnstile widget with new theme
          var tw = document.querySelector('.cf-turnstile');
          if (tw) {
            if (window.turnstile && window.__turnstileWidgetId) {
              try {
                window.turnstile.remove(window.__turnstileWidgetId);
                window.__turnstileWidgetId = window.turnstile.render(tw, { sitekey: tw.getAttribute('data-sitekey'), theme: t });
              } catch(e) { console.warn('Turnstile re-render failed:', e); }
            }
          }
          var btn = document.getElementById('theme-toggle');
          if (btn) btn.setAttribute('aria-label', 'Switch to ' + (t === 'dark' ? 'light' : 'dark') + ' mode');
        };

        window.__toggleTheme = function() {
          var current = document.documentElement.getAttribute('data-theme');
          window.__setTheme(current === 'dark' ? 'light' : 'dark');
        };

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function(e) {
          if (!localStorage.getItem('theme')) {
            window.__setTheme(e.matches ? 'dark' : 'light');
          }
        });
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href="/bot.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preload critical fonts to reduce render-blocking -->
    <link rel="preload" href="/fonts/JetBrainsMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />

    <SEO title={title} description={description} ogType={ogType} />

    <!-- Structured Data - Person Schema -->
    <script type="application/ld+json" set:html={personSchemaJSON}></script>

    <!-- Structured Data - Website Schema -->
    <script type="application/ld+json" set:html={websiteSchemaJSON}></script>

    <!-- Page-specific JSON-LD slot -->
    <slot name="head" />

    <link rel="preconnect" href="https://load.sgtm.henriksoderlund.com/" crossorigin />
    <link rel="dns-prefetch" href="https://load.sgtm.henriksoderlund.com/" />

    <!-- Initialize dataLayer before GTM -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        'environment': location.hostname === 'localhost' || location.hostname === '127.0.0.1' || location.hostname.endsWith('.workers.dev') ? 'development' : 'production'
      });
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>
      // Only load GTM in production (not on localhost or when NODE_ENV is development)
      if (location.hostname !== 'localhost' && location.hostname !== '127.0.0.1' && !location.hostname.endsWith('.workers.dev')) {
        (function (w, d, s, l, i) {
          w[l] = w[l] || [];
          w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = d.getElementsByTagName(s)[0], j = d.createElement(s);
          j.async = true;
          j.src = "https://load.sgtm.henriksoderlund.com/dz4d7tyirczbv.js?" + i;
          f.parentNode.insertBefore(j, f);
        })(window, document, 'script', 'dataLayer', '6at4snq=aWQ9R1RNLUZXUjQ%3D&omNe=daQSaS');
      }
    </script>
    <!-- End Google Tag Manager -->

    <!-- View Transitions -->
    <style is:global>
      @view-transition { navigation: auto; }
      ::view-transition-old(root) { animation: none; }
      ::view-transition-new(root) { animation: none; }
    </style>
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://load.sgtm.henriksoderlund.com/ns.html?id=GTM-FWR4" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->

    <noscript><img src="https://api.fouanalytics.com/api/noscript-6686ht0xp1ec4dc5q5z4.gif" alt="Fathom Analytics tracking pixel" /></noscript>

    <div class="app">
      <NavigationBox />
      <ThemeToggle />
      <GitHubLink />
      <LinkedInLink />

      <main class="main-content">
        <slot />
      </main>

      <Footer />
    </div>
  </body>
</html>
